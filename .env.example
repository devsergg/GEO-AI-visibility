# ── Bright Data ───────────────────────────────────────────────────────────────
BRIGHTDATA_API_TOKEN=your_brightdata_api_token_here
BRIGHTDATA_ZONE=mcp_unlocker
CHATGPT_DATASET_ID=gd_m7aof0k82r803d5bjm          # ChatGPT scraper dataset ID (validated 2026-05-28)
PERPLEXITY_DATASET_ID=gd_m7dhdot1vw9a7gc1n        # Perplexity scraper dataset ID
GEMINI_DATASET_ID=gd_mbz66arm2mf9cu856y           # Gemini scraper dataset ID (validated 2026-05-29)
GOOGLE_AI_MODE_DATASET_ID=gd_mcswdt6z2elth3zqr2   # Google AI Mode Search dataset ID (validated 2026-05-29, ~5 min latency)

# ── LLM keys ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                          # Required for variation, sentiment, recommendations
ANTHROPIC_API_KEY=                             # Optional
AIML_API_KEY=                                  # Optional alternative LLM

# ── Cognee (local, no cloud subscription needed) ──────────────────────────────
LLM_API_KEY=sk-...                             # Same value as OPENAI_API_KEY — Cognee reads this separately
ENABLE_BACKEND_ACCESS_CONTROL=false
VECTOR_DB_SUBPROCESS_ENABLED=false
GRAPH_DATABASE_SUBPROCESS_ENABLED=false
