# ── Bright Data ───────────────────────────────────────────────────────────────
BRIGHTDATA_API_TOKEN=your_brightdata_api_token_here
BRIGHTDATA_ZONE=mcp_unlocker
PERPLEXITY_DATASET_ID=gd_m7dhdot1vw9a7gc1n   # Perplexity scraper dataset ID

# ── LLM keys ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                          # Required for variation, sentiment, recommendations
ANTHROPIC_API_KEY=                             # Optional
AIML_API_KEY=                                  # Optional alternative LLM

# ── Cognee (local, no cloud subscription needed) ──────────────────────────────
LLM_API_KEY=sk-...                             # Same value as OPENAI_API_KEY — Cognee reads this
ENABLE_BACKEND_ACCESS_CONTROL=false
VECTOR_DB_SUBPROCESS_ENABLED=false             # Required for Streamlit compatibility
GRAPH_DATABASE_SUBPROCESS_ENABLED=false        # Required for Streamlit compatibility
